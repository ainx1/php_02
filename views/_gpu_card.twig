{% import "macros.twig" as ui %}

<div class="col-md-6 mb-4">
    <div class="card h-100 shadow-sm">
        {# Предполагаем, что в объекте item есть путь к картинке #}
        <img src="{{ item.image }}" class="card-img-top" alt="{{ item.title }}">
        <div class="card-body text-center">
            <h5 class="card-title">{{ item.title }}</h5>
            
            {# Главная кнопка серии #}
            {{ ui.btn(item.title, item.url, true, "primary") }}
            
            <div class="mt-2">
                {# Кнопки Картинка и Описание переводятся в стиль link (active = false) #}
                {{ ui.btn("Картинка", item.url ~ "/image", false) }}
                {{ ui.btn("Описание", item.url ~ "/info", false) }}
            </div>
        </div>
    </div>
</div>