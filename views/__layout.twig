<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>

    <style>
        .active {
            font-weight: bold;
            color: red;
        }
    </style>
</head>
<body>

    <div>
        {% for item in menu %}
            <a href="{{item.url}}" class="{{ title == item.title ? 'active' }}">{{item.title}}</a>
        {% endfor %}
    </div>

    {% block content %}
        пустота
    {% endblock %}
    
</body>
</html>