{% extends "__layout.twig" %}

{% block content %}
    Поиск

    <form action="">
        <select name="type">
            <option value="GTX">GTX</option>
            <option value="RTX">RTX</option>
        </select>
        <label>Название <input type="text" name="title"></label>
        <button type="submit">Найти</button>
    </form>

    <div class="row">
    {% for obj in objects %}
            <a href="/videocards_object/{{ obj.id }}">{{ obj.title }}</a>
    {% else %}
        Ничего не найдено
    {% endfor %}
    </div>

{% endblock %}